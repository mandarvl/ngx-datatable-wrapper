{
  "name": "@mandarvl/ngx-datatable-wrapper",
  "version": "2.0.0",
  "description": "A powerful, reusable wrapper for @swimlane/ngx-datatable",
  "scripts": {
    "build": "ng-packagr -p ng-package.json",
    "watch": "ng-packagr -p ng-package.json --watch",
    "postbuild": "cp README.md dist/ngx-datatable-wrapper/",
    "deploy": "npm run build && cd dist/ngx-datatable-wrapper && npm publish --access public"
  },
  "author": "mandarvl",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/mandarvl/ngx-datatable-wrapper"
  },
  "keywords": [
    "angular",
    "datatable",
    "ngx-datatable",
    "wrapper"
  ],
  "peerDependencies": {
    "@angular/common": "^19.0.0",
    "@angular/core": "^19.0.0",
    "@angular/forms": "^19.0.0",
    "@angular/router": "^19.0.0",
    "@swimlane/ngx-datatable": "^20.1.0",
    "@ngx-translate/core": "^16.0.0",
    "ngx-bootstrap": "^19.0.0",
    "@ng-select/ng-select": "^14.0.0",
    "moment": "^2.30.1",
    "tslib": "^2.3.0"
  },
  "dependencies": {
    "tslib": "^2.3.0"
  },
  "devDependencies": {
    "ng-packagr": "^19.0.0",
    "typescript": "~5.5.0",
    "@angular/compiler-cli": "^19.0.0",
    "@angular/compiler": "^19.0.0",
    "@angular/core": "^19.0.0",
    "@angular/common": "^19.0.0"
  },
  "sideEffects": false
}

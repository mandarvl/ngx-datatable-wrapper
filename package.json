{
  "name": "@mandarvl/ngx-datatable-wrapper",
  "version": "1.0.0",
  "description": "A powerful, reusable wrapper for @swimlane/ngx-datatable",
  "scripts": {
    "build": "ng-packagr -p ng-package.json",
    "watch": "ng-packagr -p ng-package.json --watch",
    "postbuild": "cp README.md dist/ngx-datatable-wrapper/",
    "deploy": "npm run build && cd dist/ngx-datatable-wrapper && npm publish --access public"
  },
  "author": "mandarvl",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/mandarvl/ngx-datatable-wrapper"
  },
  "keywords": [
    "angular",
    "datatable",
    "ngx-datatable",
    "wrapper"
  ],
  "peerDependencies": {
    "@angular/common": "^18.0.3",
    "@angular/core": "^18.0.3",
    "@angular/forms": "^18.0.3",
    "@angular/router": "^18.0.3",
    "@swimlane/ngx-datatable": "^20.1.0",
    "@ngx-translate/core": "^15.0.0",
    "ngx-bootstrap": "^18.0.2",
    "@ng-select/ng-select": "^13.9.1",
    "moment": "^2.30.1",
    "sweetalert2": "^11.10.6",
    "tslib": "^2.3.0"
  },
  "dependencies": {
    "tslib": "^2.3.0"
  },
  "devDependencies": {
    "ng-packagr": "^18.0.0",
    "typescript": "~5.4.2",
    "@angular/compiler-cli": "^18.0.3",
    "@angular/compiler": "^18.0.3",
    "@angular/core": "^18.0.3",
    "@angular/common": "^18.0.3"
  },
  "sideEffects": false
}
